  <style>
    .promotor-marquee {
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent 0, #000 6%, #000 94%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0, #000 6%, #000 94%, transparent 100%);
    }

    .promotor-marquee-track {
      display: flex;
      width: max-content;
      animation: promotor-marquee-scroll 44s linear infinite;
      will-change: transform;
    }

    .promotor-marquee-group {
      display: flex;
      gap: 1rem;
      padding-right: 1rem;
    }

    .promotor-marquee-card {
      position: relative;
      width: clamp(150px, 19vw, 220px);
      aspect-ratio: 1 / 1;
      flex: 0 0 auto;
      overflow: hidden;
      border-radius: 1rem;
      border: 1px solid rgb(229 231 235);
      box-shadow: 0 10px 20px rgba(15, 23, 42, 0.08);
      background: rgb(243 244 246);
    }

    .promotor-marquee-caption {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      margin: 0;
      padding: 0.75rem 0.7rem;
      color: #fff;
      font-size: 0.85rem;
      font-weight: 600;
      line-height: 1.2;
      text-align: center;
      background: linear-gradient(180deg, rgba(17, 24, 39, 0) 0%, rgba(17, 24, 39, 0.85) 100%);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    }

    .promotor-marquee:hover .promotor-marquee-track {
      animation-play-state: paused;
    }

    @keyframes promotor-marquee-scroll {
      from {
        transform: translate3d(0, 0, 0);
      }
      to {
        transform: translate3d(-50%, 0, 0);
      }
    }

    @media (max-width: 640px) {
      .promotor-marquee-track {
        animation-duration: 34s;
      }
      .promotor-marquee-card {
        width: clamp(135px, 42vw, 170px);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .promotor-marquee-track {
        animation: none;
      }
    }
  </style>
</BaseLayout>
